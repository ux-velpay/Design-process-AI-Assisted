   {n:'Ship',l:G,d:'usuario · 0.5w',ag:'—',us:'Registra el prototipo y marca el gate.',note:'Un artifact vive solo en la conversación: hay que hospedarlo donde el equipo lo abra.'}
  ]},
 {id:'rd',name:'Rediseño',badge:'~8 semanas',
