const LEADCLASS={a:'lead-a',u:'lead-u',c:'lead-c',g:'gate'};
const WPCLASS={a:'wp-a',u:'wp-u',c:'wp-c',g:'wp-g'};
const LEADNAME={a:'Lidera el agente',u:'Lidera el usuario',c:'Compartido',g:'Ship · gate'};

let curRoute=0, curPhase=0;

function buildRouteTabs(){
  const w=document.getElementById('rtabs');
  w.innerHTML=ROUTES.map((r,i)=>`<button role="tab" data-r="${i}" aria-selected="${i===curRoute}">${r.name}</button>`).join('');
}
function renderRoute(){
  const r=ROUTES[curRoute];
  document.getElementById('r-name').textContent=r.name;
  document.getElementById('r-badge').textContent=r.badge;
  document.getElementById('r-why').textContent=r.why;
  document.querySelectorAll('#rtabs button').forEach(b=>b.setAttribute('aria-selected', b.dataset.r==curRoute));
  const ph=document.getElementById('phases');
  ph.innerHTML=r.phases.map((p,i)=>`
    <button class="ph ${LEADCLASS[p.l]} ${i===curPhase?'sel':''}" data-p="${i}">
      <span class="nm">${p.n}</span><span class="mt who">${p.d}</span>
    </button>`).join('');
  renderDetail();
}
function renderDetail(){
  const p=ROUTES[curRoute].phases[curPhase];
  const ag = p.ag==='—' ? '<em>Esta fase no la ejecuta el agente.</em>' : p.ag;
  document.getElementById('detail').innerHTML=`
    <p class="k">${ROUTES[curRoute].name}</p>
    <h3>${p.n}</h3>
    <span class="who-pill ${WPCLASS[p.l]}">${LEADNAME[p.l]} · ${p.d}</span>
    <p class="lbl">Qué hace el agente</p><p>${ag}</p>
    <p class="lbl">Qué hace el usuario</p><p>${p.us}</p>
    ${p.note?`<p class="note">${p.note}</p>`:''}`;
}
document.getElementById('rtabs').addEventListener('click',e=>{
  const b=e.target.closest('button'); if(!b)return;
  curRoute=+b.dataset.r; curPhase=0; renderRoute();
});
document.getElementById('phases').addEventListener('click',e=>{
  const b=e.target.closest('button'); if(!b)return;
  curPhase=+b.dataset.p;
  document.querySelectorAll('#phases .ph').forEach(x=>x.classList.toggle('sel',x===b));
  renderDetail();
});
document.querySelector('.views').addEventListener('click',e=>{
  const b=e.target.closest('button'); if(!b)return;
  document.querySelectorAll('.views button').forEach(x=>x.setAttribute('aria-selected',x===b));
  const v=b.dataset.view;
  document.querySelectorAll('.view').forEach(x=>x.classList.remove('on'));
  document.getElementById('v-'+v).classList.add('on');
});
buildRouteTabs(); renderRoute();
</script>
